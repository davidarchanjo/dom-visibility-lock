{
  "name": "dom-visibility-lock",
  "version": "0.1.0",
  "description": "Lock DOM element visibility using MutationObserver",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "dom",
    "mutationobserver",
    "visibility",
    "frontend",
    "utility"
  ],
  "author": {
    "name": "David Archanjo",
    "email": "david.archanjoybr@gmail.com",
    "url": "https://www.linkedin.com/in/davidarchanjo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidarchanjo/dom-visibility-lock.git"
  },
  "bugs": {
    "email": "david.archanjoybr@gmail.com",
    "url": "https://github.com/davidarchanjo/dom-visibility-lock/issues"
  },
  "publishConfig": {
  "access": "public"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "rollup": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT"
}
